{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Serve (Web UI)",
      "type": "debugpy",
      "request": "launch",
      "module": "src.main",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "env": {
        "HF_HUB_CACHE": "${workspaceFolder}/models"
      }
    },
    {
      "name": "Run Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-v"],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python"
    },
    {
      "name": "Scrape Heemkring",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scraped/scrape.py",
      "cwd": "${workspaceFolder}/scraped",
      "python": "${workspaceFolder}/scraped/.venv/bin/python"
    }
  ]
}
